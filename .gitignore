# Global ignores for Python projects
__pycache__/
*.py[cod]
*$py.class

# virtual environments
.venv/
.venv-*/
venv/
env/
ENV/
env.bak/
venv.bak/

# SQLite database files
*.db
*.sqlite3

# Log files and runtime data
logs/
*.log

# IDE/editor directories
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS system files
.DS_Store

# Rust artifacts
/firewall/target/
**/target/
Cargo.lock

# Node.js dependencies
/acehack(1)/acehack/node_modules/
/acehack(1)/acehack/dist/
/acehack(1)/acehack/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vite cache
/acehack(1)/acehack/.vite/

# Environment variable files
.env
.env.*

# Python packaging
*.egg-info/
dist/
build/

# Compiled binaries
*.exe
*.dll
*.so
*.dylib

# Coverage
.coverage
coverage.xml
htmlcov/

# miscellaneous
*.swp
*~
.#*
*.lock

